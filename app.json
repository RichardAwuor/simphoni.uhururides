{
  "expo": {
    "name": "UhuruRide",
    "slug": "Uhuru Rides",
    "version": "1.0.15",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/ddfba13d-cffc-48ea-b0a9-ad8a51016563.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5C518"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/ddfba13d-cffc-48ea-b0a9-ad8a51016563.png",
        "backgroundColor": "#F5C518"
      },
      "package": "com.uhururides.app",
      "versionCode": 16
    },
    "web": {
      "favicon": "./assets/images/b5bc66af-b6dd-4cb6-821a-39afe88833d9.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "uhurueastafricais",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://6xuwggnntbur5tepaqz2vf5huf3dshcq.app.specular.dev"
    }
  }
}