{
  "expo": {
    "name": "Uhuru-Rides",
    "slug": "uhuru-rides",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/app-icon-xst.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.placeholder.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/b5bc66af-b6dd-4cb6-821a-39afe88833d9.png",
        "backgroundColor": "#F5C518"
      },
      "package": "com.placeholder.app"
    },
    "web": {
      "favicon": "./assets/images/b5bc66af-b6dd-4cb6-821a-39afe88833d9.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "expo-secure-store"
    ],
    "scheme": "nativelyapp",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "backendUrl": "https://nf4zm6czzrgy3q3wc2m4tw4wehqtga8b.app.specular.dev"
    }
  }
}